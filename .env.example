# ── Required: at least one LLM provider key ─────────────────────────────────
# Pick a provider for the main model. The admin UI exposes this as a dropdown.
# Valid LLM_PROVIDER values: openrouter, deepseek, anthropic, openai, xai,
# alibaba (DashScope), zai (GLM), kimi-coding, minimax, huggingface
# Default if unset: openrouter (preserves prior single-provider behaviour).

# Recommended: OpenRouter (access to all models via one key)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openai/gpt-4o-mini

# Or: direct OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Or: direct Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5

# ── Optional: Auxiliary model (used for context compression) ─────────────────
# Leave AUX_PROVIDER blank to mirror LLM_PROVIDER. AUX_MODEL defaults to
# google/gemini-2.0-flash-001 (lightweight, cheap).
# AUX_PROVIDER=openrouter
# AUX_MODEL=google/gemini-2.0-flash-001

# ── Optional: Tool APIs ──────────────────────────────────────────────────────

# Web search (pick one or more)
EXA_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=

# Image generation
FAL_KEY=

# Cross-session user modeling
HONCHO_API_KEY=

# GitHub (higher rate limits for code tools)
GITHUB_TOKEN=

# ── Optional: Browser automation ─────────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Gateway security ──────────────────────────────────────────────────────────
# Set to false and configure allowlists if you want to restrict access
GATEWAY_ALLOW_ALL_USERS=true

# ── Terminal backend ──────────────────────────────────────────────────────────
# Options: local, docker, modal, ssh
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
# Working dir for the terminal tool. Default /data/workspace; avoid /tmp
# because hermes installs an AGENTS.md there that would otherwise be picked
# up as agent context.
# TERMINAL_CWD=/data/workspace
